---
import ButtonLink from '../components/core/ButtonLink.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/paths';
---

<BaseLayout
  title="Page not found"
  description="The requested page does not exist in Fairus In'am Pratama's portfolio."
  canonicalPath="/404.html"
>
  <section class="section">
    <div class="container not-found">
      <p class="eyebrow">404</p>
      <h1>Page not found</h1>
      <p class="lede">The address may have changed, or the page may no longer be available.</p>
      <ButtonLink href={withBase('/')}>
        <svg
          class="button__icon button__icon--back-arrow"
          viewBox="0 0 20 20"
          fill="currentColor"
          width="18"
          height="18"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M9.707 14.707a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 1.414L7.414 9H17a1 1 0 110 2H7.414l2.293 2.293a1 1 0 010 1.414z"
            clip-rule="evenodd"></path>
        </svg>
        Return to the portfolio
      </ButtonLink>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    display: grid;
    max-width: 46rem;
    gap: var(--space-5);
  }
</style>
