---
import { getCollection } from 'astro:content';
import ButtonLink from '../components/core/ButtonLink.astro';
import SectionHeading from '../components/core/SectionHeading.astro';
import ProjectCard from '../components/work/ProjectCard.astro';
import SupportingProject from '../components/work/SupportingProject.astro';
import { capabilities } from '../data/capabilities';
import { experience } from '../data/experience';
import { leadership } from '../data/leadership';
import { site } from '../data/site';
import { supportingWork } from '../data/supporting-work';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/paths';

const work = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
const leadProject = work[0];
const secondaryProjects = work.slice(1);
---

<BaseLayout>
  <section class="hero">
    <div class="container hero__grid">
      <div class="hero__content">
        <p class="eyebrow">Laravel backend &middot; Full-stack delivery</p>
        <h1>{site.name}</h1>
        <p class="hero__positioning">{site.positioning}</p>
        <p class="lede">{site.introduction}</p>
        <div class="button-row">
          <ButtonLink href={withBase('/#selected-work')}>
            Explore selected work
            <svg
              class="button__icon button__icon--arrow"
              viewBox="0 0 20 20"
              fill="currentColor"
              width="18"
              height="18"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z"
                clip-rule="evenodd"></path>
            </svg>
          </ButtonLink>
          <ButtonLink href={withBase('/#contact')} variant="secondary">
            <svg
              class="button__icon"
              viewBox="0 0 20 20"
              fill="currentColor"
              width="18"
              height="18"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M18 10c0 3.866-3.582 7-8 7a8.841 8.841 0 01-4.083-.98L1 17l1.338-3.123C1.493 12.76 1 11.434 1 10c0-3.866 3.582-7 8-7s8 3.134 8 7zM7 9H5v2h2V9zm8 0h-2v2h2V9zM9 9h2v2H9V9z"
                clip-rule="evenodd"></path>
            </svg>
            Start a conversation
          </ButtonLink>
          {
            site.cvUrl && (
              <ButtonLink href={withBase(site.cvUrl)} variant="secondary">
                <svg
                  class="button__icon"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  width="18"
                  height="18"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z"
                    clip-rule="evenodd"
                  />
                </svg>
                View CV
              </ButtonLink>
            )
          }
        </div>
      </div>
      <aside class="hero__proof" aria-label="Engineering focus">
        <p class="eyebrow">Engineering focus</p>
        <ul>
          <li>
            <strong>Operational problems</strong><span
              >Requirements translated into explicit workflows.</span
            >
          </li>
          <li>
            <strong>Connected systems</strong><span
              >Payments, MikroTik, APIs, email, and WhatsApp.</span
            >
          </li>
          <li>
            <strong>Production delivery</strong><span
              >Testing, CI/CD, deployment, and troubleshooting.</span
            >
          </li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section section--bordered" id="selected-work">
    <div class="container">
      <SectionHeading
        eyebrow="Selected work"
        title="Systems that connect software decisions with real operations"
        description="Four focused case studies show complementary evidence across product delivery, monitoring, billing, migration, document integrity, and deployment."
      />
      <div class="work-grid">
        {leadProject && <ProjectCard entry={leadProject} variant="lead" />}
        <div class="work-grid__secondary">
          {secondaryProjects.map((entry) => <ProjectCard entry={entry} />)}
        </div>
        <SupportingProject item={supportingWork} />
      </div>
    </div>
  </section>

  <section class="section section--bordered" id="experience">
    <div class="container">
      <SectionHeading
        eyebrow="Experience"
        title="Application work grounded in operational environments"
        description="Experience spans internal ISP systems, client application delivery, and approval-oriented business software."
      />
      <ol class="timeline">
        {
          experience.map((item) => (
            <li class="timeline__item">
              <div>
                <p class="timeline__period">{item.period}</p>
                <h3>{item.role}</h3>
                <p class="timeline__organization">{item.organization}</p>
              </div>
              <p>{item.summary}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="section section--bordered" id="capabilities">
    <div class="container">
      <SectionHeading
        eyebrow="Technical capabilities"
        title="A backend foundation with enough full-stack range to deliver"
        description="The emphasis is not a list of tools; it is the ability to connect data, workflows, integrations, and production operation."
      />
      <div class="capability-grid">
        {
          capabilities.map((group) => (
            <article class="capability">
              <h3>{group.title}</h3>
              <ul>
                {group.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--bordered" id="leadership">
    <div class="container leadership-grid">
      <SectionHeading
        eyebrow="Leadership"
        title="Structured communication beyond application code"
        description="Organizational work adds evidence of documentation, mentoring, coordination, and responsibility."
      />
      <article class="leadership">
        <p class="eyebrow">{leadership.organization}</p>
        <p class="leadership__roles">
          {
            leadership.roles.map((role, index) => {
              const [title, period] = role.split(' \u00b7 ');
              return (
                <span class="leadership__role">
                  {index > 0 && (
                    <span class="separator" aria-hidden="true">
                      {' '}
                      &middot;{' '}
                    </span>
                  )}
                  <strong>{title}</strong> <span class="period">({period})</span>
                </span>
              );
            })
          }
        </p>
        <p class="leadership__summary">{leadership.summary}</p>
      </article>
    </div>
  </section>

  <section class="section contact" id="contact">
    <div class="container contact__inner">
      <div>
        <p class="eyebrow">Contact</p>
        <h2>Discuss a Laravel or business-systems role</h2>
        <p>
          Fairus is based in {site.location} and is interested in backend, backend-oriented full-stack,
          application-development, and internal-tools opportunities.
        </p>
      </div>
      <div class="button-row">
        <ButtonLink href={`mailto:${site.email}`}>
          <svg
            class="button__icon"
            viewBox="0 0 20 20"
            fill="currentColor"
            width="18"
            height="18"
            aria-hidden="true"
          >
            <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
            <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
          </svg>
          Email Fairus
        </ButtonLink>
        <ButtonLink href={site.linkedin} variant="secondary">
          <svg
            class="button__icon"
            viewBox="0 0 24 24"
            fill="currentColor"
            width="18"
            height="18"
            aria-hidden="true"
          >
            <path
              d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
            ></path>
          </svg>
          LinkedIn
        </ButtonLink>
        <ButtonLink href={site.github} variant="secondary">
          <svg
            class="button__icon"
            viewBox="0 0 24 24"
            fill="currentColor"
            width="18"
            height="18"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.137 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z"
            ></path>
          </svg>
          GitHub
        </ButtonLink>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: clamp(4.5rem, 8vw, 7rem);
  }

  .hero__grid,
  .hero__content,
  .hero__proof,
  .work-grid {
    display: grid;
    gap: var(--space-6);
  }

  .hero__content {
    align-content: center;
    max-width: 47rem;
    gap: var(--space-5);
  }

  .hero h1 {
    max-width: 12ch;
    font-weight: 650;
  }

  .hero__positioning {
    max-width: 38ch;
    font-size: var(--step-2);
    font-weight: 600;
    line-height: 1.35;
    color: var(--color-text);
  }

  .hero__proof {
    align-content: start;
    padding: clamp(var(--space-5), 3vw, var(--space-6));
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, var(--color-border));
    border-radius: var(--radius-lg);
    background: var(--color-surface-soft);
    box-shadow: var(--shadow-emphasis);
  }

  .hero__proof ul {
    display: grid;
    gap: var(--space-4);
    padding: 0;
    list-style: none;
  }

  .hero__proof li {
    display: grid;
    gap: var(--space-1);
  }
  .hero__proof li + li {
    padding-top: var(--space-4);
    border-top: 1px solid color-mix(in srgb, var(--color-accent) 16%, var(--color-border));
  }

  .hero__proof span,
  .timeline__organization,
  .timeline__item > p,
  .leadership > p:last-child,
  .contact p {
    color: var(--color-muted);
  }

  .work-grid__secondary,
  .capability-grid {
    display: grid;
    gap: var(--space-5);
  }

  .timeline {
    display: grid;
    padding: 0;
    list-style: none;
  }

  .timeline__item {
    display: grid;
    gap: var(--space-4);
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .timeline__period {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }

  .timeline__item h3 {
    margin-top: var(--space-2);
  }

  .timeline__organization {
    margin-top: var(--space-1);
  }

  .capability-grid {
    overflow: hidden;
    gap: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--color-surface-soft) 40%, var(--color-surface));
  }

  .capability {
    padding: var(--space-6);
  }

  .capability + .capability {
    border-top: 1px solid var(--color-border);
  }

  .capability ul {
    margin-top: var(--space-4);
  }

  .capability li + li {
    margin-top: var(--space-2);
  }

  .leadership-grid,
  .contact__inner {
    display: grid;
    gap: var(--space-6);
  }

  .leadership {
    padding-left: var(--space-6);
    border-left: 2px solid var(--color-accent);
  }

  .leadership__roles {
    margin-block: var(--space-2) var(--space-3);
    font-size: var(--step-1);
    color: var(--color-text);
  }

  .leadership__role {
    display: inline-block;
  }

  .leadership__roles .separator {
    color: var(--color-border);
    margin-inline: var(--space-3);
  }

  .leadership__roles .period {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    font-weight: 700;
  }

  .leadership__summary {
    color: var(--color-muted);
  }

  .leadership__summary {
    color: var(--color-muted);
  }

  .contact {
    background: var(--color-text);
    color: white;
  }

  .contact .eyebrow,
  .contact p {
    color: #c6d8d6;
  }

  .contact__inner > div:first-child {
    display: grid;
    max-width: 46rem;
    gap: var(--space-3);
  }

  .contact :global(.button:not(.button--secondary)) {
    border-color: white;
    background: white;
    color: var(--color-text);
  }

  .contact :global(.button:not(.button--secondary):hover) {
    border-color: var(--color-surface-soft);
    background: var(--color-surface-soft);
  }

  .contact :global(.button--secondary) {
    border-color: #9eb6b3;
    color: white;
  }

  .contact :global(.button--secondary:hover) {
    border-color: white;
    background: rgb(255 255 255 / 8%);
    color: white;
  }

  @media (min-width: 48rem) {
    .work-grid__secondary {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .work-grid__secondary > :global(:last-child:nth-child(odd)) {
      grid-column: 1 / -1;
    }

    .timeline__item {
      grid-template-columns: minmax(15rem, 0.8fr) 1.2fr;
      gap: var(--space-7);
    }
  }

  @media (min-width: 72rem) {
    .hero__grid {
      grid-template-columns: minmax(0, 1.42fr) minmax(18rem, 0.58fr);
      align-items: center;
      gap: var(--space-8);
    }

    .capability-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .capability + .capability {
      border-top: 0;
      border-left: 1px solid var(--color-border);
    }

    .leadership-grid,
    .contact__inner {
      grid-template-columns: minmax(0, 1.2fr) minmax(20rem, 0.8fr);
      align-items: center;
    }

    .contact__inner {
      justify-content: space-between;
    }

    .contact__inner .button-row {
      justify-content: flex-end;
    }
  }
</style>
