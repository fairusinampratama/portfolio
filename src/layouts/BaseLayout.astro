---
import SiteFooter from '../components/core/SiteFooter.astro';
import SiteHeader from '../components/core/SiteHeader.astro';
import SeoHead from '../components/core/SeoHead.astro';
import { site } from '../data/site';
import { withBase } from '../lib/paths';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  type?: 'website' | 'article';
}

const {
  title = site.name,
  description = site.defaultDescription,
  canonicalPath,
  type = 'website',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#f6f7f4" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <SeoHead title={title} description={description} canonicalPath={canonicalPath} type={type} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <SiteHeader />
    <main id="main-content">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
