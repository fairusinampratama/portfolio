---
import FlowDiagram from './FlowDiagram.astro';

const steps = [
  { title: 'Authenticate', detail: 'The Gin API validates the application key.' },
  { title: 'Route', detail: 'Handlers translate HTTP requests into RouterOS operations.' },
  {
    title: 'Queue',
    detail: 'Commands enter a worker channel instead of competing for one connection.',
  },
  {
    title: 'Serialize',
    detail: 'A worker goroutine processes operations in a controlled sequence.',
  },
  {
    title: 'Connect',
    detail: 'Persistent router connections are reused and re-established when needed.',
  },
  {
    title: 'Respond',
    detail: 'Results return through the API with structured logging and monitoring.',
  },
] as const;
---

<FlowDiagram
  title="Persistent RouterOS operation path"
  description="NetEngine separates HTTP concurrency from serialized router operations through a persistent connection and worker boundary."
  steps={steps}
/>
