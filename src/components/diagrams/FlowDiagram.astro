---
import DiagramFrame from '../work/DiagramFrame.astro';

interface Step {
  title: string;
  detail: string;
}

interface Props {
  title: string;
  description: string;
  steps: readonly Step[];
}

const { title, description, steps } = Astro.props;
---

<DiagramFrame title={title} description={description}>
  <ol class="flow">
    {
      steps.map((step, index) => (
        <li>
          <span class="flow__number" aria-hidden="true">
            {String(index + 1).padStart(2, '0')}
          </span>
          <div>
            <strong>{step.title}</strong>
            <span>{step.detail}</span>
          </div>
        </li>
      ))
    }
  </ol>
</DiagramFrame>

<style>
  .flow {
    display: grid;
    gap: var(--space-4);
    padding: 0;
    list-style: none;
    counter-reset: flow;
    max-width: 42rem;
    margin-inline: auto;
    width: 100%;
  }

  .flow li {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-3);
    align-items: start;
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    margin: 0;
  }

  .flow li:not(:first-child)::before {
    position: absolute;
    z-index: 2;
    top: calc(var(--space-4) * -1 - 2px);
    left: calc(var(--space-4) + 1.125rem - 1px);
    width: 2px;
    height: calc(var(--space-4) + 4px);
    background: var(--color-accent);
    content: '';
  }

  .flow__number {
    display: grid;
    width: 2.25rem;
    height: 2.25rem;
    place-items: center;
    border-radius: 50%;
    background: var(--color-text);
    color: white;
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .flow li div {
    display: grid;
    gap: var(--space-1);
  }

  .flow li span:last-child {
    color: var(--color-muted);
    font-size: var(--step--1);
  }
</style>
