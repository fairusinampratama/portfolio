---
import DiagramFrame from '../work/DiagramFrame.astro';

interface Step {
  title: string;
  detail: string;
}

interface Props {
  title: string;
  description: string;
  steps: readonly Step[];
}

const { title, description, steps } = Astro.props;
---

<DiagramFrame title={title} description={description}>
  <ol class="flow">
    {
      steps.map((step, index) => (
        <li>
          <span class="flow__number" aria-hidden="true">
            {String(index + 1).padStart(2, '0')}
          </span>
          <div>
            <strong>{step.title}</strong>
            <span>{step.detail}</span>
          </div>
        </li>
      ))
    }
  </ol>
</DiagramFrame>

<style>
  .flow {
    display: grid;
    gap: var(--space-3);
    padding: 0;
    list-style: none;
    counter-reset: flow;
  }

  .flow li {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-3);
    align-items: start;
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
  }

  .flow li:not(:last-child)::after {
    position: absolute;
    z-index: 1;
    bottom: calc(var(--space-3) * -1 - 1px);
    left: 1.85rem;
    width: 2px;
    height: calc(var(--space-3) + 2px);
    background: var(--color-accent);
    content: '';
  }

  .flow__number {
    display: grid;
    width: 2.25rem;
    height: 2.25rem;
    place-items: center;
    border-radius: 50%;
    background: var(--color-text);
    color: white;
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .flow li div {
    display: grid;
    gap: var(--space-1);
  }

  .flow li span:last-child {
    color: var(--color-muted);
    font-size: var(--step--1);
  }

  @media (min-width: 48rem) {
    .flow {
      grid-template-columns: repeat(var(--flow-columns, 3), minmax(0, 1fr));
    }

    .flow li {
      grid-template-columns: 1fr;
    }

    .flow li:not(:last-child)::after {
      top: 1.9rem;
      right: calc(var(--space-3) * -1 - 1px);
      bottom: auto;
      left: auto;
      width: calc(var(--space-3) + 2px);
      height: 2px;
    }
  }
</style>
