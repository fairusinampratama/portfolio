---
import { site as siteData } from '../../data/site';
import { withBase } from '../../lib/paths';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  type?: 'website' | 'article';
}

const { title, description, canonicalPath = Astro.url.pathname, type = 'website' } = Astro.props;
const fullTitle = title === siteData.name ? title : `${title} \u00b7 ${siteData.name}`;
const canonical = new URL(
  withBase(canonicalPath.replace(import.meta.env.BASE_URL, '/')),
  Astro.site,
);
const socialImage = new URL(withBase('/og-default.png'), Astro.site);
const jsonLd =
  type === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'Article',
        headline: title,
        description,
        author: { '@type': 'Person', name: siteData.name },
        url: canonical.toString(),
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'ProfilePage',
        name: fullTitle,
        description,
        url: canonical.toString(),
        mainEntity: {
          '@type': 'Person',
          name: siteData.name,
          jobTitle: siteData.title,
          sameAs: [siteData.github, siteData.linkedin],
        },
      };
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={socialImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta
  property="og:image:alt"
  content={"Fairus In'am Pratama \u00b7 Laravel Backend / Full-Stack Developer"}
/>
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={socialImage} />
<meta name="referrer" content="strict-origin-when-cross-origin" />
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
