---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="section-heading">
  <p class="eyebrow">{eyebrow}</p>
  <h2>{title}</h2>
  {description && <p>{description}</p>}
</header>

<style>
  .section-heading {
    display: grid;
    max-width: 48rem;
    gap: var(--space-3);
    margin-bottom: var(--space-7);
  }

  .section-heading > p:last-child {
    color: var(--color-muted);
  }
</style>
