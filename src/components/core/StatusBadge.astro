---
import type { WorkStatus } from '../../data/statuses';
import { statusLabels } from '../../data/statuses';

interface Props {
  status: WorkStatus;
}

const { status } = Astro.props;
const tone =
  status === 'deployed-limited-adoption'
    ? 'limited'
    : status === 'live-production' || status === 'operational'
      ? 'live'
      : 'deployed';
---

<span class:list={['status', `status--${tone}`]}>
  <span aria-hidden="true"></span>
  {statusLabels[status]}
</span>

<style>
  .status {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: var(--space-2);
    max-width: 100%;
    padding: 0.28rem 0.5rem;
    border: 0;
    border-radius: var(--radius-sm);
    font-size: var(--step--1);
    font-weight: 650;
    line-height: 1.3;
  }

  .status > span {
    width: 0.38rem;
    height: 0.38rem;
    flex: none;
    border-radius: 50%;
    background: currentColor;
  }

  .status--live {
    background: var(--color-live-bg);
    color: var(--color-live);
  }

  .status--deployed {
    background: var(--color-deployed-bg);
    color: var(--color-deployed);
  }

  .status--limited {
    background: var(--color-limited-bg);
    color: var(--color-limited);
  }
</style>
