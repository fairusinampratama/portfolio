---
import type { CollectionEntry } from 'astro:content';
import StatusBadge from '../core/StatusBadge.astro';
import TagList from '../core/TagList.astro';
import ProjectLinks from './ProjectLinks.astro';

interface Props {
  entry: CollectionEntry<'work'>;
}

const { entry } = Astro.props;
---

<header class="case-hero">
  <div class="container">
    <a class="back-link" href={import.meta.env.BASE_URL}>
      <svg
        class="back-link__icon"
        viewBox="0 0 20 20"
        fill="currentColor"
        width="16"
        height="16"
        aria-hidden="true"
      >
        <path
          fill-rule="evenodd"
          d="M9.707 14.707a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 1.414L7.414 9H17a1 1 0 110 2H7.414l2.293 2.293a1 1 0 010 1.414z"
          clip-rule="evenodd"></path>
      </svg>
      Back to portfolio
    </a>
    <div class="case-hero__grid">
      <div class="case-hero__main">
        <p class="eyebrow">{entry.data.domain}</p>
        <h1>{entry.data.displayTitle}</h1>
        <p class="lede">{entry.data.summary}</p>
        <ProjectLinks links={entry.data.links} />
      </div>
      <aside class="case-hero__rail" aria-label="Project summary">
        <StatusBadge status={entry.data.status} />
        <div>
          <strong>Professional claim</strong>
          <p>{entry.data.professionalClaim}</p>
        </div>
        <TagList items={entry.data.technologies} />
      </aside>
    </div>
  </div>
</header>

<style>
  .case-hero {
    padding-block: var(--space-7) clamp(var(--space-8), 6vw, var(--space-9));
    background: linear-gradient(
      180deg,
      var(--color-bg),
      color-mix(in srgb, var(--color-surface-soft) 34%, var(--color-bg))
    );
    border-bottom: 1px solid var(--color-border);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-7);
    font-size: var(--step--1);
    font-weight: 700;
    color: var(--color-accent);
    text-decoration: none;
    transition: color 160ms ease;
  }

  .back-link:hover {
    color: var(--color-accent-strong);
  }

  .back-link__icon {
    flex: none;
    transition: transform 160ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .back-link:hover .back-link__icon {
    transform: translateX(-3px);
  }

  .case-hero__grid,
  .case-hero__main,
  .case-hero__rail {
    display: grid;
    gap: var(--space-5);
  }

  .case-hero__main h1 {
    max-width: 15ch;
  }

  .case-hero__rail {
    align-content: start;
    padding: var(--space-5);
    border: 1px solid color-mix(in srgb, var(--color-accent) 18%, var(--color-border));
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-surface-soft) 58%, var(--color-surface));
  }

  .case-hero__rail strong {
    display: block;
    margin-bottom: var(--space-2);
    font-size: var(--step--1);
  }

  .case-hero__rail p {
    color: var(--color-muted);
  }

  @media (min-width: 72rem) {
    .case-hero__grid {
      grid-template-columns: minmax(0, var(--reading)) var(--rail);
      justify-content: space-between;
      gap: var(--space-8);
    }
  }
</style>
