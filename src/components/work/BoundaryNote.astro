---
interface Props {
  title?: string;
}

const { title = 'Evidence boundary' } = Astro.props;
---

<aside class="boundary" aria-label={title}>
  <strong>{title}</strong>
  <div><slot /></div>
</aside>

<style>
  .boundary {
    display: grid;
    gap: var(--space-2);
    padding: var(--space-5);
    border: 1px solid var(--color-border);
    border-left: 0.3rem solid var(--color-limited);
    border-radius: var(--radius-md);
    background: var(--color-limited-bg);
  }

  .boundary strong {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .boundary :global(p) {
    color: var(--color-muted);
  }
</style>
