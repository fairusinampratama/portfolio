---
import type { supportingWork } from '../../data/supporting-work';
import TagList from '../core/TagList.astro';
import NetEngineStrip from '../diagrams/NetEngineStrip.astro';

interface Props {
  item: typeof supportingWork;
}

const { item } = Astro.props;
---

<article class="supporting">
  <div>
    <p class="eyebrow">{item.label}</p>
    <h3>{item.title}</h3>
  </div>
  <p>{item.summary}</p>
  <NetEngineStrip />
  <div class="supporting__footer">
    <TagList items={item.technologies.slice(0, 4)} />
    <a href={item.repository}>Inspect public repository <span aria-hidden="true">&rarr;</span></a>
  </div>
</article>

<style>
  .supporting {
    display: grid;
    gap: var(--space-5);
    padding-block: clamp(var(--space-6), 4vw, var(--space-8));
    border-block: 1px solid var(--color-border);
  }

  .supporting h3 {
    margin-top: var(--space-2);
  }

  .supporting > p {
    max-width: 68ch;
    color: var(--color-muted);
  }

  .supporting__footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .supporting__footer > a {
    width: fit-content;
    font-weight: 700;
  }

  @media (min-width: 72rem) {
    .supporting {
      grid-template-columns: minmax(14rem, 0.7fr) minmax(0, 1.3fr);
      align-items: start;
      column-gap: var(--space-8);
    }

    .supporting > :global(.architecture-strip),
    .supporting__footer {
      grid-column: 1 / -1;
    }
  }
</style>
