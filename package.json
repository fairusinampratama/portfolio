{
  "name": "fairus-inam-pratama-portfolio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^26.5.0",
    "npm": "^12.0.1"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "check": "tsc --noEmit",
    "verify:assets": "node scripts/verify-assets.mjs",
    "test:privacy": "node scripts/check-public-output.mjs",
    "test:e2e": "playwright test --project=desktop --project=mobile",
    "test:a11y": "playwright test --project=accessibility",
    "test:lighthouse": "npx --yes @lhci/cli@latest autorun",
    "verify": "npm run format:check && npm run lint && npm run check && npm run build && npm run verify:assets && npm run test:privacy && npm run test:e2e && npm run test:a11y"
  },
  "dependencies": {
    "@astrojs/mdx": "7.0.3",
    "@astrojs/sitemap": "3.7.3",
    "astro": "7.0.8",
    "sharp": "0.35.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "7.0.2"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true
  }
}
